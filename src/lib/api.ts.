import { supabase } from './supabase';

export const getPets = async () => {
  const { data } = await supabase.from('animais').select('*');
  return data || [];
};

export const savePet = async (pet: any) => {
  const { data } = await supabase.from('animais').insert(pet);
  return data;
};

